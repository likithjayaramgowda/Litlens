# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT secret — only required for HS256 projects (pre-March 2024 Supabase).
# ES256/RS256 projects verify via JWKS; leave this blank for those.
SUPABASE_JWT_SECRET=

# ── OpenRouter — free-tier LLM (server-side only, never sent to the browser) ──
# Sign up free at openrouter.ai → Keys → Create Key
# Key format: sk-or-v1-...
OPENROUTER_API_KEY=sk-or-v1-...

# ── Per-user daily query limits ────────────────────────────────────────────────
DAILY_QUERY_LIMIT=50
DEMO_QUERY_LIMIT=10

# ── CORS (comma-separated list of allowed frontend origins) ───────────────────
# Development default is already set in config.py — only override for production.
# CORS_ORIGINS=["https://your-app.vercel.app","https://litlens.app"]

# ── Next.js public vars (available in the browser) ────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
