# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT secret — only required for HS256 projects (pre-March 2024).
# ES256/RS256 projects verify via JWKS; leave blank for those.
SUPABASE_JWT_SECRET=

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# Local dev: backend runs on host, ChromaDB runs in Docker → use localhost.
# Docker Compose (all services containerised): use the service name 'chromadb'.
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── OpenRouter — free-tier LLM (server-side key, never exposed to users) ──────
# One key gives access to 28+ free models (Gemini, DeepSeek, LLaMA, etc.)
# Sign up free at openrouter.ai → Keys → Create Key → name it "LitLens"
# Key format: sk-or-v1-...
OPENROUTER_API_KEY=sk-or-v1-...

# ── Per-user daily query limits ────────────────────────────────────────────────
# Users hitting their limit see a friendly message + prompt to add DeepSeek key.
DAILY_QUERY_LIMIT=50
DEMO_QUERY_LIMIT=10

# ── Next.js public vars (available in the browser) ────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
