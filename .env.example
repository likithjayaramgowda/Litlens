# ---------------------------------------------------------------------------
# Supabase — https://supabase.com/dashboard/project/<your-ref>/settings/api
# ---------------------------------------------------------------------------
# Used by the frontend (browser-safe, must be NEXT_PUBLIC_ prefixed)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Used by the backend only (server-side, never exposed to the browser)
SUPABASE_URL=https://your-project-ref.supabase.co
# anon key (safe, RLS-restricted) — used for general DB access
SUPABASE_KEY=your-supabase-anon-key
# service_role key (bypasses RLS — keep secret, backend only)
# Found at: Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Found at: Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ---------------------------------------------------------------------------
# ChromaDB
# ---------------------------------------------------------------------------
# When running via Docker Compose: CHROMA_HOST=chromadb, CHROMA_PORT=8000
#   (the backend container reaches the chromadb container by service name)
# When running the backend LOCALLY (not in Docker): CHROMA_HOST=localhost, CHROMA_PORT=8001
#   (Docker maps chromadb container port 8000 → host port 8001)
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ---------------------------------------------------------------------------
# Next.js — backend API base URL (used server-side in fetch calls)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
