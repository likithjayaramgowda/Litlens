# ---------------------------------------------------------------------------
# Supabase — https://supabase.com/dashboard/project/<your-ref>/settings/api
# ---------------------------------------------------------------------------
# Used by the frontend (browser-safe, must be NEXT_PUBLIC_ prefixed)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Used by the backend only (server-side, never exposed to the browser)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
# Found at: Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ---------------------------------------------------------------------------
# ChromaDB
# ---------------------------------------------------------------------------
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ---------------------------------------------------------------------------
# Next.js — backend API base URL (used server-side in fetch calls)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
